DATABASE_URL=jdbc:postgresql://localhost:5432/keepernotes
DATABASE_USERNAME=postgres
DATABASE_PASSWORD=postgres
JWT_SECRET=replace-with-a-random-256-bit-string-use-openssl-rand-base64-32
JWT_EXPIRY_MS=86400000
JWT_REFRESH_EXPIRY_MS=604800000
GOOGLE_CLIENT_ID=your-google-oauth-client-id
GOOGLE_CLIENT_SECRET=your-google-oauth-client-secret
GEMINI_API_KEY=your-gemini-api-key
REDIS_URL=redis://localhost:6379
R2_ACCOUNT_ID=your-cloudflare-account-id
R2_ACCESS_KEY=your-r2-access-key
R2_SECRET_KEY=your-r2-secret-key
R2_BUCKET_NAME=keepernotes-files
FRONTEND_URL=http://localhost:3000
# Set to true ONLY in local dev — never in production
SWAGGER_ENABLED=true
